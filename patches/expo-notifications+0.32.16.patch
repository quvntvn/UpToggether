+    // UpTogether patch: when the notification body is tagged as an alarm
+    // (data.type === "alarm"), upgrade it with a full-screen intent so the
+    // wake screen launches immediately, even on the lockscreen.
+    val isAlarm = try {
+      content.body?.optString("type") == "alarm"
+    } catch (e: Exception) {
+      false
+    }
+    if (isAlarm) {
+      builder.setFullScreenIntent(
+        createNotificationResponseIntent(
+          context,
+          notification,
+          defaultAction
+        ),
+        true
+      )
+      builder.setCategory(NotificationCompat.CATEGORY_ALARM)
+    }
+
